---
import BaseLayout from '../layouts/BaseLayout.astro';
import { AUTHOR, SOCIAL_LINKS } from '../consts';
---

<BaseLayout title="About" description={`About ${AUTHOR.name} — ${AUTHOR.jobTitle}`}>
  <h1>About Me</h1>
  <p>
    Hi! My name is Kaiwalya Kher. I love to dabble in many forms of engineering
    and science but I have gained more proficiency in computers than any other
    fields. I am a co-founder and CTO at Joy, and have been building software
    professionally for nearly two decades.
  </p>

  <div class="links">
    {SOCIAL_LINKS.map(({ label, href }) => (
      <a href={href} target="_blank" rel="noopener noreferrer">{label}</a>
    ))}
  </div>
</BaseLayout>

<style>
  h1 {
    margin-top: 0;
  }

  .links {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }
</style>
