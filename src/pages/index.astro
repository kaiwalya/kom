---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import { SITE_NAME, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const assetsUrl = import.meta.env.ASSETS_URL;

const posts = (await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={SITE_NAME} description={SITE_DESCRIPTION}>
  <div class="filter-tabs" role="tablist">
    <button class="filter-tab active" data-filter="all" role="tab" aria-selected="true">all</button>
    <button class="filter-tab" data-filter="tech" role="tab" aria-selected="false">tech</button>
    <button class="filter-tab" data-filter="astrophotography" role="tab" aria-selected="false">astro</button>
    <button class="filter-tab" data-filter="sound" role="tab" aria-selected="false">sound</button>
  </div>

  {posts.length === 0 && <p>No posts yet.</p>}

  <ul class="card-grid" role="tabpanel">
    {posts.map((post) => (
      <li data-type={post.data.type}>
        <ContentCard
          title={post.data.title}
          date={post.data.date}
          summary={post.data.summary}
          tags={post.data.tags}
          type={post.data.type}
          slug={post.id}
          image={post.data.image}
          instagramLink={post.data.instagramLink}
          draft={post.data.draft}
          assetsUrl={assetsUrl}
          hasBody={!!post.body?.trim()}
        />
      </li>
    ))}
  </ul>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const items = document.querySelectorAll<HTMLLIElement>('.card-grid li');

  function setFilter(filter: string) {
    tabs.forEach((tab) => {
      const isActive = tab.dataset.filter === filter;
      tab.classList.toggle('active', isActive);
      tab.setAttribute('aria-selected', String(isActive));
    });

    items.forEach((item) => {
      const type = item.dataset.type;
      item.style.display = filter === 'all' || type === filter ? '' : 'none';
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      setFilter(tab.dataset.filter!);
      history.replaceState(null, '', tab.dataset.filter === 'all' ? '/' : `/?filter=${tab.dataset.filter}`);
    });
  });

  const params = new URLSearchParams(window.location.search);
  const initial = params.get('filter');
  if (initial && ['tech', 'astrophotography', 'sound'].includes(initial)) {
    setFilter(initial);
  }
</script>

<style is:global>
  body {
    max-width: 64rem;
  }
</style>

<style>
  .filter-tabs {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .filter-tab {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--color-muted);
    text-transform: lowercase;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
    font-family: inherit;
  }

  .filter-tab:hover,
  .filter-tab.active {
    color: var(--color-heading);
    border-bottom-color: var(--color-heading);
  }

  .card-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1rem;
  }

  .card-grid li {
    display: flex;
  }
</style>
