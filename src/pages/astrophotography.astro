---
import BaseLayout from '../layouts/BaseLayout.astro';
import photos from '../data/astrophotography.json';
---

<BaseLayout title="Astrophotography" description="Deep-sky astrophotography by Kaiwalya Kher">
  <h1>Astrophotography</h1>
  <p class="intro">
    Deep-sky images captured from San Mateo, California.
    All photos are also on <a href="https://www.instagram.com/knkher" target="_blank" rel="noopener noreferrer">Instagram</a>.
  </p>

  <div class="gallery">
    {photos.map((photo) => (
      <a href={photo.instagram} target="_blank" rel="noopener noreferrer" class="card">
        <div class="card-body">
          <h2>{photo.title}</h2>
          <p>{photo.description}</p>
          <span class="date">{new Date(photo.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</span>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  h1 {
    margin-top: 0;
  }

  .intro {
    color: var(--color-muted);
    margin-bottom: 2rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1rem;
  }

  .card {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--color-link);
    text-decoration: none;
  }

  .card h2 {
    font-size: 1rem;
    margin: 0 0 0.5rem;
    color: var(--color-heading);
  }

  .card p {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0 0 0.5rem;
  }

  .date {
    font-size: 0.75rem;
    color: var(--color-muted);
  }
</style>
