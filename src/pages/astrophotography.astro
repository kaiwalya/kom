---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import { getCollection } from 'astro:content';

const assetsUrl = import.meta.env.ASSETS_URL;

const photos = (await getCollection('blog', ({ data }) => {
  const show = import.meta.env.PROD ? data.draft !== true : true;
  return show && data.type === 'astrophotography';
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Astrophotography" description="Deep-sky astrophotography by Kaiwalya Kher">
  <h1>Astrophotography</h1>
  <p class="intro">
    Deep-sky images captured from San Mateo, California.
    All photos are also on <a href="https://www.instagram.com/knkher" target="_blank" rel="noopener noreferrer">Instagram</a>.
  </p>

  <ul class="card-grid">
    {photos.map((photo) => (
      <li>
        <ContentCard
          title={photo.data.title}
          date={photo.data.date}
          summary={photo.data.summary}
          type="astrophotography"
          slug={photo.id}
          image={photo.data.image}
          instagramLink={photo.data.instagramLink}
          assetsUrl={assetsUrl}
        />
      </li>
    ))}
  </ul>
</BaseLayout>

<style is:global>
  body {
    max-width: 64rem;
  }
</style>

<style>
  h1 {
    margin-top: 0;
  }

  .intro {
    color: var(--color-muted);
    margin-bottom: 2rem;
  }

  .card-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1rem;
  }

  .card-grid li {
    display: flex;
  }
</style>
