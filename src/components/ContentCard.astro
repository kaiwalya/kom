---
interface Props {
  title: string;
  date: Date;
  summary?: string;
  tags?: string[];
  type: 'tech' | 'astrophotography';
  slug: string;
  image?: string;
  instagramLink?: string;
  draft?: boolean;
  assetsUrl: string;
}

const { title, date, summary, tags = [], type, slug, image, instagramLink, draft, assetsUrl } = Astro.props;

const href = type === 'astrophotography' ? instagramLink : `/blog/${slug}/`;
const isExternal = type === 'astrophotography';
---

<a href={href} class:list={['card', `card--${type}`, { draft }]} {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}>
  {type === 'astrophotography' && image && (
    <img src={`${assetsUrl}${image}`} alt={title} loading="lazy" />
  )}
  <div class="card-body">
    <h2>{title}</h2>
    {summary && <p class="summary">{summary}</p>}
    {tags.length > 0 && (
      <div class="tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
    <time datetime={date.toISOString()}>
      {date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
  </div>
</a>

<style>
  .card {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
    height: 100%;
  }

  .card:hover {
    border-color: var(--color-link);
    text-decoration: none;
  }

  .card.draft {
    opacity: 0.6;
  }

  .card.draft h2::after {
    content: ' (draft)';
    font-size: 0.75rem;
    color: var(--color-muted);
    font-weight: normal;
  }

  .card img {
    width: 100%;
    height: auto;
    display: block;
  }

  .card-body {
    padding: 0.75rem;
  }

  .card h2 {
    font-size: 0.9375rem;
    margin: 0 0 0.25rem;
    color: var(--color-heading);
  }

  .summary {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin: 0 0 0.25rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.25rem;
  }

  .tag {
    background-color: var(--color-code-bg);
    padding: 0.1em 0.5em;
    border-radius: 3px;
    font-size: 0.6875rem;
    color: var(--color-muted);
  }

  time {
    display: block;
    font-size: 0.75rem;
    color: var(--color-muted);
  }
</style>
